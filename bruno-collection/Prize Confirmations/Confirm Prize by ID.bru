meta {
  name: Confirm Prize by ID
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/prize-confirmations/:confirmationId/confirm
  body: json
  auth: bearer
}

params:path {
  confirmationId:
}

auth:bearer {
  token: {{firebase_token}}
}

body:json {
  {
    "message": "Found it! Amazing prize!",
    "contentUrl": "https://storage.googleapis.com/urbanhunt-app.appspot.com/prize-confirmations/photo123.jpg"
  }
}