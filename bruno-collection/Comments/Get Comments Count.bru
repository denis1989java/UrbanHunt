meta {
  name: Get Comments Count
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/challenges/{{challengeId}}/comments/count
  body: none
  auth: none
}

vars:pre-request {
  challengeId: m4KE9sXWr10Fa2RcMsFY
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });
  
  test("should return number", function() {
    expect(res.body).to.be.a('number');
  });
}
